# Gemini API Key (Required for AI generation)
# Get one from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Database URL (Optional, defaults to sqlite:///./equilens.db)
# For Postgres: postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./equilens.db
